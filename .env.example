# Astrosis Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/astrosis
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration (Caching & Rate Limiting)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# API Rate Limiting (requests per minute)
RATE_LIMIT_FREE=100
RATE_LIMIT_PRO=1000
RATE_LIMIT_ENTERPRISE=10000

# TLE Data Source
CELESTRAK_API_URL=https://celestrak.org/NORAD/elements/gp.php
TLE_REFRESH_INTERVAL_HOURS=6

# Security
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY_LENGTH=32

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Physics Engine
PHYSICS_ENGINE_PATH=./backend/cpp/build/physics_engine.so
